    "description": "Checks date chaining, file filtering, size follow-up, tool protocol, and hallucination fallbacks.",
    "fixtures": {
      "current_time": "2026-05-08T14:01:32"
    },
    "turns": [
      {
        "input": "Hi my name is Carlos, and you?",
        "llm_responses": [
          {
            "content": "Hello Carlos. I am a helpful professional assistant.",
            "reasoning_content": "Greeting only; no tool needed."
          }
        ],
        "expected_tools": [],
        "forbidden_tools": [
          "get_current_time",
          "list_current_directory",
          "add_numbers"
        ],
        "assertions": {
          "answer_contains": [
            "Carlos"
          ],
          "memory_valid": true
        }
      },
      {
        "input": "Can you tell today and tomorrow date?",
        "llm_responses": [
          {
            "content": "",
            "tool_calls": [
              {
                "id": "call_time_1",
                "name": "get_current_time",
                "arguments": {}
              }
            ],
            "reasoning_content": "Use get_current_time, then calculate tomorrow."
          },
          {
            "content": "Today is May 14, 2025, and tomorrow is May 15, 2025.",
            "reasoning_content": "Bad final text that should be overridden by deterministic fallback."
          }
        ],
        "expected_tools": [
          "get_current_time"
        ],
        "forbidden_tools": [
          "add_numbers"
        ],
        "assertions": {
          "answer_contains": [
            "2026-05-08",
            "2026-05-09"
          ],
          "answer_not_contains": [
            "2025"
          ],
          "date_answer_matches_tool_result": true,
          "grounded_in_tool_results": true,
          "memory_valid": true,
          "fallback_used": true
        },
        "live_assertions": {
          "answer_not_contains": [
            "2025"
          ],
          "date_answer_matches_tool_result": true,
          "grounded_in_tool_results": true,
          "memory_valid": true
        }
      },
      {
        "input": "What about yesterday?",
        "llm_responses": [
          {
            "content": "Yesterday was 2026-05-07.",
            "reasoning_content": "Direct answer, but adapter should still infer time tool."
